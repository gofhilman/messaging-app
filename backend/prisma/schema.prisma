// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  username String    @unique
  password String
  name     String
  picture  String    @default("https://res.cloudinary.com/dwyzndpyq/image/upload/v1772863199/customer-100_sld3om.png")
  online   Boolean   @default(false)
  chats    Chat[]
  messages Message[]
}

model Chat {
  id            String    @id @default(uuid())
  lastMessageAt DateTime?
  name          String?
  read          Boolean   @default(true)
  type          ChatType
  users         User[]
  messages      Message[]
}

model Message {
  id        String      @id @default(uuid())
  createdAt DateTime
  chat      Chat?       @relation(fields: [chatId], references: [id])
  chatId    String?
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  type      MessageType
  text      String?
  image     String?
}

enum ChatType {
  PRIVATE
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
}
